# --- Server ---
NODE_ENV=development
PORT=3000
# Base URL used to build the full short link returned to clients
BASE_URL=http://localhost:3000
# Comma-separated CORS allowlist, or "*" to allow all origins
CORS_ORIGINS=*
LOG_LEVEL=info

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/url_shortener

# --- Auth (Better Auth) ---
# Signing/encryption secret, 32+ chars. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-32-char-min-random-secret
# Public base URL Better Auth issues links/cookies for.
BETTER_AUTH_URL=http://localhost:3000

# --- Email (Resend — required in production) ---
# Dev/test: emails are logged, not sent. Production requires both vars below.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=URL Shortener <onboarding@yourdomain.com>

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# --- Sqids (short-code generation) ---
# Minimum length of generated short codes
SQIDS_MIN_LENGTH=6
# Optional custom alphabet (must be unique chars). Set a shuffled alphabet per
# deployment so codes aren't predictable from the public default. Leave blank
# to use the default.
SQIDS_ALPHABET=
