# --- Server ---
NODE_ENV=development
PORT=3000
# Base URL used to build the full short link returned to clients
BASE_URL=http://localhost:3000
# Comma-separated CORS allowlist, or "*" to allow all origins
CORS_ORIGINS=*
LOG_LEVEL=info

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/url_shortener

# --- Auth ---
# Secret used to sign access JWTs. Use a long random string in production.
JWT_ACCESS_SECRET=change-me-access-secret
# Access token lifetime (e.g. 15m, 1h)
ACCESS_TOKEN_TTL=15m
# Refresh token lifetime in days
REFRESH_TOKEN_TTL_DAYS=7
JWT_ISSUER=url-shortener
JWT_AUDIENCE=url-shortener-clients

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# --- Maintenance ---
# Minutes between purges of expired/revoked refresh tokens
TOKEN_CLEANUP_INTERVAL_MIN=60

# --- Sqids (short-code generation) ---
# Minimum length of generated short codes
SQIDS_MIN_LENGTH=6
# Optional custom alphabet (must be unique chars). Set a shuffled alphabet per
# deployment so codes aren't predictable from the public default. Leave blank
# to use the default.
SQIDS_ALPHABET=
