            "body": {
              "mode": "raw",
              "raw": "{\n  \"memberId\": \"{{memberId}}\",\n  \"role\": \"admin\",\n  \"organizationId\": \"{{organizationId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/organization/update-member-role",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "organization", "update-member-role"]
            },
            "description": "Changes a member's role (owner | admin | member). Requires admin/owner."
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sessionToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"memberIdOrEmail\": \"teammate@example.com\",\n  \"organizationId\": \"{{organizationId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/organization/remove-member",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "organization", "remove-member"]
            },
            "description": "Removes a member by member id or email. Requires admin/owner."
          }
        },
        {
          "name": "Leave Organization",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sessionToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"organizationId\": \"{{organizationId}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/auth/organization/leave",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "organization", "leave"]
            },
            "description": "The current user leaves the organization. Owners must transfer ownership first."
          }
        },
        {
          "name": "Delete Organization",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sessionToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"organizationId\": \"{{organizationId}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/auth/organization/delete",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "organization", "delete"]
            },
            "description": "Permanently deletes the organization (and cascades its short links). Requires owner."
          }
        }
      ]
    },
    {
      "name": "URLs",
      "description": "Tenant-scoped short links. Every operation acts within the caller's active organization (set via Organization > Set Active Organization).",
      "item": [
        {
          "name": "Create Short URL",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.code) pm.collectionVariables.set('shortCode', res.code);",
                  "pm.test('201 Created', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sessionToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com/some/very/long/path?with=query\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/urls",
              "host": ["{{baseUrl}}"],
              "path": ["api", "urls"]
            },
            "description": "Creates a short link owned by the active organization. Requires an active org (403 NO active organization otherwise).\n\nOptional fields: customAlias (3-32 chars) and expiresAt (future ISO date), e.g.\n{\n  \"url\": \"https://example.com\",\n  \"customAlias\": \"promo\",\n  \"expiresAt\": \"2030-01-01T00:00:00Z\"\n}"
          }
        },
        {
          "name": "List Org URLs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{sessionToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/urls?limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "urls"],
              "query": [
                { "key": "limit", "value": "20" },
                { "key": "offset", "value": "0" }
              ]
            },
            "description": "Lists the active organization's short links (paginated)."
          }
        },
        {
          "name": "URL Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{sessionToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/urls/{{shortCode}}/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "urls", "{{shortCode}}", "stats"]
            },
            "description": "Click stats for a link owned by the active organization."
          }
        },
        {
          "name": "Delete Short URL",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('204 No Content', () => pm.response.to.have.status(204));"]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{sessionToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/urls/{{shortCode}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "urls", "{{shortCode}}"]
            },
            "description": "Soft-deletes a link owned by the active organization."
          }
        },
        {
          "name": "Redirect (follow short code)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{shortCode}}",
              "host": ["{{baseUrl}}"],
              "path": ["{{shortCode}}"]
            },
            "description": "Public route — returns a 302 to the original URL (410 if expired). Tip: disable Settings > 'Automatically follow redirects' to see the 302 + Location header."
          }
        }
      ]
    }
  ]
}
