            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{sessionToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/organization/list-members?organizationId={{organizationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "organization", "list-members"],
              "query": [{ "key": "organizationId", "value": "{{organizationId}}" }]
